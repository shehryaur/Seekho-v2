# ─────────────────────────────────────────────────────────────────────
# Seekho Engine — example environment variables
#
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored. NEVER commit real keys.
# Variable names mirror the ones used inside the existing codebase
# (see lib/supabase.ts and the API routes under app/api).
# ─────────────────────────────────────────────────────────────────────

# Google Gemini (used by /api/generate, /api/weekly-planner, /api/parent-whatsapp)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase — public values (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase — server-only service key (NEVER expose to browser)
# Note: this matches the variable name used in your current code.
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Optional — base URL for share links
NEXT_PUBLIC_SITE_URL=http://localhost:3000
