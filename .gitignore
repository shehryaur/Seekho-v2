# ─────────────────────────────────────────────────────────────────────
# Seekho Engine — .gitignore
# Replace your old single-line .gitignore with this.
# ─────────────────────────────────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Next.js build output
.next/
out/
build/
dist/

# Production
.vercel/

# Environment files — NEVER commit real keys
.env
.env*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db

# Testing
coverage/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Supabase local
supabase/.branches
supabase/.temp

# Misc
*.log
.cache/
